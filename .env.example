# Copy to .env and fill in real values. .env is gitignored — never commit it.
# Shape documented in PROJECT.md Section 6.

# --- Shared (common/config.py) ---
# Host-side tools/tests use the development override's bound port. Containers
# receive their own internal DSN from docker-compose.yml.
POSTGRES_DSN=postgresql+asyncpg://trademind:trademind@localhost:55432/trademind
REDIS_URL=redis://localhost:6379/0

# --- llm_service only. Never inject into freqtrade, admin_api, or notifier. ---
# LLM_PROVIDER selects which providers/*.py implementation get_provider()
# returns (PROJECT.md Section 8.4) — "anthropic" (hosted) or "ollama"
# (self-hosted, via the ollama/ollama-pull compose services).
LLM_PROVIDER=anthropic
LLM_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
# Only used when LLM_PROVIDER=ollama. OLLAMA_BASE_URL defaults to the
# in-network ollama compose service; override OLLAMA_MODEL to any model tag
# `ollama pull` accepts (bigger models need more RAM/CPU and may exceed the
# bounded /analyze timeout without a GPU — see DEPLOYMENT.md Prerequisites).
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b
# Sampling temperature for Ollama generation. Keep this low enough for valid,
# repeatable JSON and consistent rubric evaluation. The prompt deliberately
# contains no phrase-rich action examples for a small model to copy.
OLLAMA_TEMPERATURE=0.4

# --- scheduler ---
# Candle period cycles run on. Must divide evenly into 1h (5m/10m/15m/30m/1h).
# Analyze every closed thirty-minute candle — fewer, less noisy signals than
# 5m, and lower round-trip fee drag.
TIMEFRAME=30m
# Run after each candle closes, allowing the exchange candle to settle.
CANDLE_SETTLE_SECOND=15
# Keep each CPU-only model call isolated. The final symbol offset must remain
# below TIMEFRAME. Measured ~75s/call on qwen2.5:7b (CPU-only), so a 70s
# stagger keeps calls close to back-to-back without queuing; at 16 symbols
# the last offset lands at +1065s, leaving ~735s of headroom before the next
# 30m candle boundary (~67% utilization at steady state).
SYMBOL_STAGGER_SECONDS=70
# Raised from 180/185 now that TIMEFRAME=30m leaves much more slack per
# candle period, to give the CPU-only default model (qwen2.5:7b, ~75s/call
# observed) more room to finish before failing closed to HOLD.
ANALYZE_TIMEOUT_SECONDS=300
LLM_REQUEST_TIMEOUT_SECONDS=305
# Four recent candles are enough to evaluate the three-candle price pattern
# while keeping CPU-only Qwen inference inside the per-symbol stagger budget.
LLM_OHLCV_WINDOW=4
# Comma-separated, no spaces required. Also drives freqtrade's pair_whitelist
# (freqtrade/docker-entrypoint.sh) — the two must always match, so this is
# the one place to edit either. Remove an entry to stop trading that symbol
# without any code change; each added symbol needs
# candle_settle_second + index * symbol_stagger_seconds to stay under
# TIMEFRAME's seconds, or the scheduler refuses to start (PROJECT.md Section
# 5.1). That guard alone allows ~24 symbols at 30m/70s-stagger, but real
# per-call latency (~75s on CPU-only qwen2.5:7b) is the tighter constraint —
# each added symbol adds ~75s of serial work per candle period, so budget
# against the 1800s window, not just the stagger-offset ceiling.
SYMBOLS=BTC/USDT,ETH/USDT,BNB/USDT,XRP/USDT,SOL/USDT,ADA/USDT,DOGE/USDT,LINK/USDT,AVAX/USDT,DOT/USDT,LTC/USDT,TRX/USDT,ATOM/USDT,NEAR/USDT,UNI/USDT,ETC/USDT

# --- freqtrade, risk_engine only. Never inject into llm_service. ---
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- notifier ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# admin_api base URL the notifier calls back into for /killswitch_on and
# /killswitch_off slash commands (PROJECT.md Section 11: Telegram is a
# client of the API, not a parallel control path).
ADMIN_API_URL=http://admin_api:8000

# --- admin_api (auth), also consumed by notifier as the credential it
# presents when calling back into admin_api ---
ADMIN_API_KEY=

# --- risk_engine (internal-network-only Freqtrade REST credentials) ---
FREQTRADE_API_URL=http://freqtrade:8080
FREQTRADE_API_USER=
FREQTRADE_API_PASS=
RECONCILIATION_INTERVAL_SECONDS=60
RECONCILIATION_ORDER_AGE_MINUTES=10

# --- freqtrade only (api_server's own JWT signing key, not used by our
# risk_engine client, which authenticates with HTTP Basic auth instead).
# Freqtrade requires at least 32 characters. ---
FREQTRADE_JWT_SECRET=

# --- freqtrade, risk_engine ---
# Must be true for the MVP; flipping to false requires human review (PROJECT.md Section 14).
DRY_RUN=true

# --- freqtrade, admin_api (authenticates the Freqtrade -> admin_api webhook) ---
WEBHOOK_SHARED_SECRET=
WEBHOOK_URL=http://admin_api:8000/webhooks/freqtrade
